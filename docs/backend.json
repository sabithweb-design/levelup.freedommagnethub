
{
  "entities": {
    "Program": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Program",
      "type": "object",
      "description": "Represents a single learning program, containing all content and metadata required for its public landing page on the LearnVista platform.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Program entity."
        },
        "title": {
          "type": "string",
          "description": "The main title or name of the learning program."
        },
        "subtitle": {
          "type": "string",
          "description": "A descriptive subtitle for the learning program."
        },
        "titleFontSize": {
          "type": "number",
          "description": "Font size for the main title in pixels."
        },
        "subtitleFontSize": {
          "type": "number",
          "description": "Font size for the subtitle in pixels."
        },
        "lineHeight": {
          "type": "number",
          "description": "Line height for the main heading."
        },
        "letterSpacing": {
          "type": "number",
          "description": "Letter spacing for the main heading in pixels."
        },
        "textAlign": {
          "type": "string",
          "enum": ["left", "center", "right"],
          "description": "Text alignment for the hero content."
        },
        "demoVideoId": {
          "type": "string",
          "description": "The YouTube video ID for the main demo video."
        },
        "gallery": {
          "type": "array",
          "items": { "type": "string" },
          "description": "URLs for images in the gallery."
        },
        "videoTestimonials": {
          "type": "array",
          "items": { "type": "string" },
          "description": "YouTube IDs for video testimonials."
        },
        "imageTestimonials": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        },
        "features": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" },
              "iconName": { "type": "string" }
            }
          }
        },
        "faqs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": { "type": "string" },
              "answer": { "type": "string" }
            }
          }
        },
        "joinButtonLink": {
          "type": "string",
          "format": "uri"
        },
        "expiryDate": {
          "type": "string",
          "format": "date-time"
        },
        "oldPriceLabel": {
          "type": "string",
          "description": "Strikethrough price label, e.g., 'Join ₹1000 / month'"
        },
        "currentPriceLabel": {
          "type": "string",
          "description": "Active price highlight, e.g., 'Now Pay ₹589 today'"
        },
        "priceSubtext": {
          "type": "string",
          "description": "Small text below active price, e.g., '(₹499 + GST) Lifetime Access'"
        }
      },
      "required": [
        "id",
        "title",
        "subtitle",
        "demoVideoId",
        "joinButtonLink",
        "expiryDate"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/programs/{programId}",
        "definition": {
          "entityName": "Program",
          "schema": {
            "$ref": "#/backend/entities/Program"
          },
          "description": "Stores individual learning program landing page content."
        }
      },
      {
        "path": "/roles_admin/{userId}",
        "definition": {
          "entityName": "AdminRole",
          "description": "Stores documents representing administrator roles."
        }
      }
    ]
  }
}
